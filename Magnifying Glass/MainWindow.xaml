<Window x:Class="Magnifying_Glass.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Magnifying_Glass"
        mc:Ignorable="d"
        Title="放大镜" Height="450" Width="800">
    <Window.Background>
        <SolidColorBrush Color="#2D2D30"/>
    </Window.Background>
    <StackPanel Margin="20">
        <StackPanel.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Margin" Value="0,10,0,5"/>
            </Style>
        </StackPanel.Resources>

        <TextBlock Text="缩放级别: x2.0" x:Name="TxtZoom"/>
        <Slider x:Name="SldZoom" Minimum="1" Maximum="5" Value="2" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SldZoom_ValueChanged"/>

        <TextBlock Text="范围大小: 200px" x:Name="TxtSize"/>
        <Slider x:Name="SldSize" Minimum="100" Maximum="600" Value="200" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SldSize_ValueChanged"/>

        <TextBlock Text="刷新率: 60 FPS (延迟 ~16ms)" x:Name="TxtFps"/>
        <Slider x:Name="SldFps" Minimum="10" Maximum="144" Value="60" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SldFps_ValueChanged"/>

        <TextBlock Text="快捷键:" FontWeight="Bold" Margin="0,20,0,5"/>
        <TextBlock Text="F8: 隐藏/显示 控制面板"/>
        <TextBlock Text="F9: 启用/禁用 放大镜"/>

    </StackPanel>
</Window>

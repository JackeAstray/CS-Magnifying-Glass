<Window x:Class="Magnifying_Glass.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Magnifying_Glass"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Background>
        <SolidColorBrush Color="#2D2D30"/>
    </Window.Background>
    <StackPanel Margin="20">
        <StackPanel.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Margin" Value="0,10,0,5"/>
            </Style>
        </StackPanel.Resources>

        <TextBlock Text="Zoom Level: x2.0" x:Name="TxtZoom"/>
        <Slider x:Name="SldZoom" Minimum="1" Maximum="5" Value="2" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SldZoom_ValueChanged"/>

        <TextBlock Text="Size: 200px" x:Name="TxtSize"/>
        <Slider x:Name="SldSize" Minimum="100" Maximum="600" Value="200" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SldSize_ValueChanged"/>

        <TextBlock Text="Hotkeys:" FontWeight="Bold" Margin="0,20,0,5"/>
        <TextBlock Text="F8: Hide/Show Control Panel"/>
        <TextBlock Text="F9: Enable/Disable Magnifier"/>

    </StackPanel>
</Window>
